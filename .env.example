# ── LLM Provider ──────────────────────────────────────────────────────────────
# Default provider: openai | anthropic | ollama | mock
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local) — no key needed, just set base URL
OLLAMA_BASE_URL=http://localhost:11434

# ── Pipeline Settings ──────────────────────────────────────────────────────────
MAX_TOKENS=512
TEMPERATURE=0.0
TIMEOUT_SECONDS=30

# ── RAG Settings ──────────────────────────────────────────────────────────────
# mock | chromadb
RAG_BACKEND=mock
CHROMA_PERSIST_DIR=./data/chroma_db
TOP_K_DOCS=3

# ── Evaluation Thresholds ─────────────────────────────────────────────────────
HALLUCINATION_THRESHOLD=0.05
P95_LATENCY_MS=5000
MIN_ANSWER_RELEVANCY=0.70
MIN_FAITHFULNESS=0.75
MAX_COST_PER_QUERY=0.01

# ── Dashboard ─────────────────────────────────────────────────────────────────
RESULTS_DIR=./results
